<div class="upload-container">
    

    
    <div class="upload-card">

        <h1 class="upload-title">
            Document Verification
        </h1>

        <p class="upload-subtitle">
            Upload all required documents for verification.
        </p>

        <form asp-controller="Document"
              asp-action="Upload"
              method="post"
              enctype="multipart/form-data">

            <div class="document-grid" id="documentGrid">

                <div class="document-box">
                    <div class="document-icon">🪪</div>
                    <div class="document-title">Aadhaar Card</div>
                    <div style="
                        color:#6b7280;
                        font-size:13px;
                        margin-bottom:10px;">
                        PDF only • Max 2 MB
                    </div>

                    <div class="drop-zone">
                        <span class="drop-zone__prompt">
                            Drag & Drop Aadhaar<br />
                            or Click to Browse
                        </span>

                        <input type="file"
                               name="AadhaarFile"
                               accept=".pdf"
                               class="drop-zone__input" />
                    </div>
                </div>

                <div class="document-box">
                    <div class="document-icon">💳</div>
                    <div class="document-title">PAN Card</div>
                    <div style="
                        color:#6b7280;
                        font-size:13px;
                        margin-bottom:10px;">
                        PDF only • Max 2 MB
                    </div>

                    <div class="drop-zone">
                        <span class="drop-zone__prompt">
                            Drag & Drop PAN<br />
                            or Click to Browse
                        </span>

                        <input type="file"
                               name="PanFile"
                               accept=".pdf"
                               class="drop-zone__input" />

                    </div>
                </div>

                <div class="document-box">
                    <div class="document-icon">📄</div>
                    <div class="document-title">Other Document</div>
                    <div style="
                        color:#6b7280;
                        font-size:13px;
                        margin-bottom:10px;">
                        PDF only • Max 2 MB
                    </div>

                    <div class="drop-zone">
                        <span class="drop-zone__prompt">
                            Drag & Drop Document<br />
                            or Click to Browse
                        </span>

                        <input type="file"
                               name="OtherFile"
                               accept=".pdf"
                               class="drop-zone__input" />
                    </div>
                </div>

                <div id="addDocumentBtn"
                     class="document-box add-document-card">

                    <div class="add-document-icon">➕</div>

                    <div class="add-document-text">
                        Add Document
                    </div>

                </div>

            </div>

            <button type="submit"
                    id="uploadBtn"
                    class="submit-btn">
                Upload Documents
            </button>

        </form>
        @if (ViewBag.Progress != null)
        {
            <div class="upload-container mb-4">

                <div style="
                    background:white;
                    border-radius:24px;
                    padding:10px;
                    box-shadow:0 10px 30px rgba(108,99,255,.08);">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <h4 style="
                            font-weight:800;
                            margin:0;
                            color:#1a1a2e;
                            font-size:24px;">
                            Verification Progress
                        </h4>

                            <span style="
                                background:linear-gradient(135deg,#6C63FF,#8B5CF6);
                                color:white;
                                padding:8px 18px;
                                border-radius:50px;
                                font-weight:700;">
                                @ViewBag.Progress%
                            </span>

                    </div>

                        <div style="
                            height:8px;
                            background:#edf2ff;
                            border-radius:50px;
                            overflow:hidden;">

                            <div style="
                                height:100%;
                                width:@ViewBag.Progress%;
                                background:linear-gradient(
                                135deg,
                                #6C63FF,
                                #8B5CF6);">
                            </div>

                        </div>

                        <div class="row mt-4">

                            <div class="col-md-4 mb-3">

                                <div style="
                                    background:#fafbff;

                                    border-radius:18px;
                                    padding:12px;
                                    text-align:center;">

                                    <div style="font-size:28px;">
                                        @(string.IsNullOrEmpty(ViewBag.MainDocument?.AadhaarPath)
                                            ? "❌"
                                            : "✅")
                                    </div>

                                    <h5>Aadhaar Card</h5>

                                    <div style="color:#6b7280;">
                                        @(string.IsNullOrEmpty(ViewBag.MainDocument?.AadhaarPath)
                                            ? "Not Uploaded"
                                            : "Uploaded")
                                    </div>

                                </div>

                            </div>

                            <div class="col-md-4 mb-3">

                                <div style="
                                    background:#fafbff;
                                    border-radius:18px;
                                    padding:12px;
                                    text-align:center;">

                                    <div style="font-size:28px;">
                                        @(string.IsNullOrEmpty(ViewBag.MainDocument?.PanPath)
                                            ? "❌"
                                            : "✅")
                                    </div>

                                    <h5>PAN Card</h5>

                                    <div style="color:#6b7280;">
                                        @(string.IsNullOrEmpty(ViewBag.MainDocument?.PanPath)
                                            ? "Not Uploaded"
                                            : "Uploaded")
                                    </div>

                                </div>

                            </div>

                            <div class="col-md-4 mb-3">

                                <div style="
                                    background:#fafbff;
                                    border-radius:18px;
                                    padding:12px;
                                    text-align:center;">

                                    <div style="font-size:28px;">

                                        @(ViewBag.DocumentStatus == "Approved"
                                            ? "🟢"
                                            : ViewBag.DocumentStatus == "Rejected"
                                            ? "🔴"
                                            : "🟡")

                                    </div>

                                    <h5>Status</h5>

                                    <div style="
                                        font-weight:700;
                                        color:#6C63FF;">

                                        @ViewBag.DocumentStatus

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
        }

        @if (ViewBag.MainDocument != null)
        {
            <div class="mt-5">

                    <h5 style="font-weight:700;">
                        Uploaded Documents
                    </h5>

                <div class="card p-3 mt-3">

                    @if (!string.IsNullOrEmpty(ViewBag.MainDocument.AadhaarPath))
                    {
                        <div class="d-flex justify-content-between mb-2">

                            <span>
                                📄 Aadhaar Card
                            </span>

                            <a href="@ViewBag.MainDocument.AadhaarPath"
                               target="_blank"
                               class="btn btn-sm btn-primary">
                                View
                            </a>

                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.MainDocument.PanPath))
                    {
                        <div class="d-flex justify-content-between mb-2">

                            <span>
                                📄 PAN Card
                            </span>

                            <a href="@ViewBag.MainDocument.PanPath"
                               target="_blank"
                               class="btn btn-sm btn-primary">
                                View
                            </a>

                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.MainDocument.OtherDocumentPath))
                    {
                        <div class="d-flex justify-content-between">

                            <span>
                                📄 Other Document
                            </span>

                            <a href="@ViewBag.MainDocument.OtherDocumentPath"
                               target="_blank"
                               class="btn btn-sm btn-primary">
                                View
                            </a>

                        </div>
                    }

                </div>

            </div>
        }

        @if (ViewBag.UserDocuments != null)
        {
            <div class="mt-4">

                <h5 style="font-weight:700;">
                    Additional Documents
                </h5>

                <div class="card p-3 mt-3">

                    @foreach (var doc in ViewBag.UserDocuments)
                    {
                        <div class="d-flex justify-content-between mb-2">

                            <span>
                                📄 @doc.DocumentName
                            </span>

                            <a href="@doc.FilePath"
                               target="_blank"
                               class="btn btn-sm btn-success">

                                View

                            </a>

                        </div>
                    }

                </div>

            </div>
        }

    </div>
    

</div>

<script>

    let documentCounter = 0;

    initializeDropZones();

    document
    .getElementById("addDocumentBtn")
    .addEventListener("click", function () {

        documentCounter++;

        const html = `
        <div class="document-box">

            <div class="document-icon">📎</div>

            <div class="document-title">
                <div style="
                        color:#6b7280;
                        font-size:13px;
                        margin-bottom:10px;">
                        PDF only • Max 2 MB
                </div>
                Additional Document ${documentCounter}
            </div>

            <input type="text"
                   name="ExtraDocumentNames"
                   class="document-name"
                   placeholder="Enter Document Name" />

            <div class="drop-zone">

                <span class="drop-zone__prompt">
                    Drag & Drop File<br>
                    or Click to Browse
                </span>

                <input type="file"
                   name="ExtraFiles"
                   accept=".pdf"
                   class="drop-zone__input" />

            </div>

        </div>
        `;

        document
        .getElementById("addDocumentBtn")
        .insertAdjacentHTML("beforebegin", html);

        initializeDropZones();
    });

    function initializeDropZones() {

        document.querySelectorAll(".drop-zone__input")
        .forEach(input => {

            const dropZone =
                input.closest(".drop-zone");

            if (dropZone.dataset.ready)
                return;

            dropZone.dataset.ready = "1";

               input.addEventListener("change", () => {

        if (input.files.length) {

            const file = input.files[0];

            // Only PDF
            if (file.type !== "application/pdf") {

                alert("Only PDF files are allowed.");

                input.value = "";

                return;
            }

            // Max 2 MB
            if (file.size > 2 * 1024 * 1024) {

                alert("File size must be less than 2 MB.");

                input.value = "";

                return;
            }

            updateThumbnail(
                dropZone,
                file);
        }
    });

            dropZone.addEventListener("dragover", e => {

                e.preventDefault();

                dropZone.classList.add(
                    "drop-zone--over");
            });

            dropZone.addEventListener("dragleave", () => {

                dropZone.classList.remove(
                    "drop-zone--over");
            });

            dropZone.addEventListener("drop", e => {

                e.preventDefault();

                if (e.dataTransfer.files.length) {

                    input.files =
                        e.dataTransfer.files;

                    updateThumbnail(
                        dropZone,
                        e.dataTransfer.files[0]);
                }

                dropZone.classList.remove(
                    "drop-zone--over");
            });

        });
    }

            function updateThumbnail(dropZone, file) 
            {

            let thumb =
                dropZone.querySelector(".drop-zone__thumb");

            if (!thumb) {

                thumb =
                    document.createElement("div");

                thumb.classList.add(
                    "drop-zone__thumb");

                dropZone.appendChild(thumb);
            }

            const sizeMB =
                (file.size / 1024 / 1024).toFixed(2);

            thumb.innerHTML =
                `
                ✅ Selected File
                <br><br>
                <strong>${file.name}</strong>
                <br>
                <small>${sizeMB} MB</small>
                `;
            }
    

        document.querySelector("form")
    .addEventListener("submit", function () {

        const btn =
            document.getElementById("uploadBtn");

        btn.disabled = true;

        btn.innerHTML =
            "Uploading Documents...";
    });

</script>
