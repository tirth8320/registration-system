@{
    ViewData["Title"] = "Document Upload";
}

<style>

    .upload-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .upload-card {
        background: white;
        border-radius: 24px;
        padding: 25px;
        box-shadow: 0 15px 35px rgba(108,99,255,.08);
        border: 1px solid #eef0ff;
    }

    .upload-title {
        font-size: 36px;
        font-weight: 800;
        color: #1a1a2e;
        margin-bottom: 10px;
    }

    .upload-subtitle {
        color: #8b8bb0;
        margin-bottom: 25px;
    }

    .document-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .document-box {
        background: #fafbff;
        border: 2px dashed #d7d9ff;
        border-radius: 20px;
        padding: 25px;
        min-height: 100px;
        text-align: center;
        transition: .3s;
        display: flex;
        flex-direction: column;
    }

        .document-box:hover {
            transform: translateY(-4px);
            border-color: #6C63FF;
            box-shadow: 0 10px 25px rgba(108,99,255,.12);
        }

    .document-icon {
        font-size: 55px;
        margin-bottom: 12px;
    }

    .document-title {
        font-size: 20px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 15px;
    }

    .document-name {
        border: 1px solid #d7d9ff;
        border-radius: 12px;
        padding: 10px;
        width: 100%;
        margin-bottom: 15px;
        text-align: center;
    }

    .drop-zone {
        position: relative;
        border: 2px dashed #6C63FF;
        border-radius: 16px;
        min-height: 120px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: white;
        cursor: pointer;
        transition: .3s;
        margin-top: auto;
    }

        .drop-zone:hover {
            background: #f4f3ff;
        }

    .drop-zone--over {
        background: #f0eeff;
    }

    .drop-zone__input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    .drop-zone__prompt {
        color: #6C63FF;
        font-weight: 700;
        text-align: center;
    }

    .drop-zone__thumb {
        color: #22c55e;
        font-weight: 700;
        padding: 15px;
        text-align: center;
        word-break: break-word;
    }

    .add-document-card {
        border: 2px dashed #6C63FF;
        background: #f8f7ff;
        cursor: pointer;
        justify-content: center;
        align-items: center;
    }

        .add-document-card:hover {
            background: #f0eeff;
        }

    .add-document-icon {
        font-size: 70px;
        color: #6C63FF;
    }

    .add-document-text {
        margin-top: 15px;
        font-size: 22px;
        font-weight: 700;
        color: #6C63FF;
    }

    .submit-btn {
        width: 100%;
        margin-top: 25px;
        border: none;
        border-radius: 14px;
        padding: 16px;
        font-size: 18px;
        font-weight: 700;
        color: white;
        background: linear-gradient(135deg,#6C63FF,#8B5CF6);
    }

    img {
        max-width: 100%;
        height: auto;
    }

    @@media (max-width: 768px) {
        .upload-container {
            width: 100%;
            padding: 0 0.5rem;
        }

        .upload-card {
            padding: 1rem;
        }

        .upload-title {
            font-size: 1.6rem;
        }

        .document-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .document-box {
            padding: 1rem;
        }

        .document-title {
            font-size: 1rem;
        }

        .drop-zone,
        .document-name,
        .drop-zone__input {
            width: 100%;
        }

        .submit-btn,
        .btn {
            width: 100%;
            min-height: 48px;
        }

        .d-flex.justify-content-between {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 0.5rem;
        }
    }

    @@media (max-width: 576px) {
        .upload-title {
            font-size: 1.35rem;
        }

        .upload-subtitle {
            font-size: 0.85rem;
        }

        .add-document-icon {
            font-size: 44px;
        }

        .add-document-text {
            font-size: 1rem;
        }
    }

</style>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger"
         style="
        max-width:1200px;
        margin:20px auto;
        border-radius:12px;
        font-weight:600;">

        ❌ @TempData["Error"]

    </div>
}


