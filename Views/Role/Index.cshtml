@model IEnumerable<registration.Models.RoleMaster>

@{
    ViewData["Title"] = "RoleMaster";
}

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.5s ease both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-title {
        font-family: 'Syne',sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: #1A1A2E;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

        .page-title .title-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg,#6C63FF,#8B5CF6);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.1rem;
            box-shadow: 0 4px 15px rgba(108,99,255,0.3);
        }

    .user-count-pill {
        background: rgba(108,99,255,0.1);
        color: #6C63FF;
        border-radius: 50px;
        padding: 0.25rem 0.9rem;
        font-size: 0.8rem;
        font-weight: 700;
        border: 1px solid rgba(108,99,255,0.2);
    }

    .search-wrapper {
        position: relative;
        width: 280px;
    }

    .search-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: #9898B5;
        font-size: 0.95rem;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 0.55rem 1rem 0.55rem 2.4rem;
        border: 1.5px solid rgba(108,99,255,0.18);
        border-radius: 50px;
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 0.88rem;
        color: #1A1A2E;
        background: white;
        transition: all 0.25s ease;
        outline: none;
    }

        .search-input:focus {
            border-color: #6C63FF;
            box-shadow: 0 0 0 4px rgba(108,99,255,0.1);
        }

    .table-card {
        background: white;
        border: 1px solid rgba(108,99,255,0.1);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(108,99,255,0.09);
        animation: fadeUp 0.5s ease 0.1s both;
    }

        .table-card table {
            margin: 0;
        }

        .table-card thead tr {
            background: linear-gradient(135deg,rgba(108,99,255,0.06),rgba(56,189,248,0.06));
        }

        .table-card thead th {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #9898B5;
            padding: 1rem 1.2rem;
            border: none;
            white-space: nowrap;
        }

        .table-card tbody td {
            padding: 0.9rem 1.2rem;
            vertical-align: middle;
            border-bottom: 1px solid rgba(108,99,255,0.05);
            font-size: 0.88rem;
            color: #4A4A6A;
        }

        .table-card tbody tr:last-child td {
            border: none;
        }

        .table-card tbody tr {
            transition: all 0.2s ease;
        }

            .table-card tbody tr:hover td {
                background: rgba(108,99,255,0.03);
            }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg,#6C63FF,#8B5CF6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .user-name {
        font-weight: 600;
        color: #1A1A2E;
    }

    .user-id {
        font-size: 0.75rem;
        color: #9898B5;
    }

    .badge-admin {
        background: linear-gradient(135deg,#FF6B6B,#FF8E53);
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .badge-user {
        background: linear-gradient(135deg,#6C63FF,#38BDF8);
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .badge-none {
        background: #F0F1FA;
        color: #9898B5;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .gender-chip {
        background: #F6F7FB;
        border: 1px solid rgba(108,99,255,0.12);
        border-radius: 50px;
        padding: 3px 10px;
        font-size: 0.78rem;
        font-weight: 600;
        color: #4A4A6A;
    }

    .action-btns {
        display: flex;
        gap: 0.4rem;
        justify-content: center;
    }

    .btn-edit {
        background: rgba(108,99,255,0.1);
        color: #6C63FF;
        border: none;
        border-radius: 8px;
        padding: 0.38rem 0.9rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: all 0.2s ease;
    }

        .btn-edit:hover {
            background: #6C63FF;
            color: white;
            transform: translateY(-1px);
        }

    .btn-delete {
        background: rgba(255,107,107,0.1);
        color: #FF6B6B;
        border: none;
        border-radius: 8px;
        padding: 0.38rem 0.9rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: all 0.2s ease;
    }

        .btn-delete:hover {
            background: #FF6B6B;
            color: white;
            transform: translateY(-1px);
        }

    .table-footer {
        padding: 0.9rem 1.5rem;
        border-top: 1px solid rgba(108,99,255,0.07);
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.82rem;
        color: #9898B5;
        font-weight: 500;
    }

    .no-results {
        padding: 4rem;
        text-align: center;
        color: #9898B5;
    }

        .no-results i {
            font-size: 3rem;
            margin-bottom: 1rem;
            display: block;
        }

    img {
        max-width: 100%;
        height: auto;
    }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .search-wrapper {
            width: 100%;
        }

        .search-input {
            width: 100%;
            font-size: 16px;
        }

        .table-card thead th,
        .table-card tbody td {
            padding: 0.65rem 0.7rem;
        }

        .action-btns {
            flex-wrap: wrap;
            justify-content: flex-start;
        }

        .btn-edit,
        .btn-delete {
            min-height: 48px;
        }
    }

    @@media (max-width: 576px) {
        .action-btns {
            flex-direction: column;
        }

        .btn-edit,
        .btn-delete {
            width: 100%;
            justify-content: center;
        }
    }
</style>
@* @model List<registration.Models.RoleMaster> *@

@{
    ViewData["Title"] = "Role Management";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <div class="title-icon">
                <i class="bi bi-shield-lock"></i>
            </div>

            Role Management

            <span class="user-count-pill">
                @Model.Count() Roles
            </span>
        </h1>

        <p style="color:#9898B5;font-size:0.85rem;margin:0.4rem 0 0 3.2rem;">
            Manage all available roles and permissions
        </p>
    </div>

    <div class="search-wrapper">
        <i class="bi bi-search search-icon"></i>

        <input type="text"
               class="search-input"
               id="searchInput"
               placeholder="Search roles..." />
    </div>
</div>

<div class="mb-3">
    <a asp-action="Create"
       class="btn-edit">
        <i class="bi bi-plus-circle"></i>
        Add Role
    </a>
</div>

<div class="table-card">

    <div class="table-responsive">

        <table class="table" id="roleTable">

            <thead>

                <tr>
                    <th><i class="bi bi-hash me-1"></i>Role</th>
                    <th>Role Name</th>
                    <th>Type</th>
                    <th class="text-center">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var role in Model)
                {
                    <tr class="role-row">

                        <td>

                            <div class="user-cell">

                                <div class="user-avatar">
                                    @(role.RoleName.Substring(0,1).ToUpper())
                                </div>

                                <div>

                                    <div class="user-name">
                                        @role.RoleName
                                    </div>

                                    <div class="user-id">
                                        #@role.RoleID
                                    </div>

                                </div>

                            </div>

                        </td>

                        <td style="font-weight:600;color:#1A1A2E;">
                            @role.RoleName
                        </td>

                        <td>

                            @if(role.RoleName == "Admin")
                            {
                                <span class="badge-admin">
                                    <i class="bi bi-shield-fill-check"></i>
                                    Admin
                                </span>
                            }
                            else
                            {
                                <span class="badge-user">
                                    <i class="bi bi-person-fill"></i>
                                    User Role
                                </span>
                            }

                        </td>

                        <td>

                            <div class="action-btns">

                                <a asp-action="Edit"
                                   asp-route-id="@role.RoleID"
                                   class="btn-edit">

                                    <i class="bi bi-pencil"></i>
                                    Edit

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@role.RoleID"
                                   class="btn-delete"
                                   onclick="return confirm('Delete this role?')">

                                    <i class="bi bi-trash"></i>
                                    Delete

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <div class="table-footer">

        <span class="user-count-pill">
            @(Model.Count()) Roles
        </span>

        <span>
            <i class="bi bi-shield-check"></i>
            Role Dashboard
        </span>

    </div>

</div>

<script>
document.getElementById("searchInput")
.addEventListener("keyup", function () {

    let value = this.value.toLowerCase();

    let rows =
        document.querySelectorAll(".role-row");

    rows.forEach(function (row) {

        row.style.display =
            row.innerText.toLowerCase()
                .includes(value)
                ? ""
                : "none";
    });
});
</script>