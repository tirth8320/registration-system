@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    .privacy-wrapper {
        max-width: 800px;
        margin: 2.5rem auto;
        padding: 0 1rem 3rem;
        animation: fadeUp 0.5s ease both;
    }
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .privacy-hero {
        background: linear-gradient(135deg, #6C63FF 0%, #8B5CF6 60%, #38BDF8 100%);
        border-radius: 24px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }

        .privacy-hero::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
        }

    .privacy-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .privacy-hero-icon {
        width: 56px;
        height: 56px;
        background: rgba(255,255,255,0.2);
        border: 1.5px solid rgba(255,255,255,0.35);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: white;
    }

    .privacy-title {
        font-family: 'Syne',sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        color: white;
        margin: 0;
    }

    .privacy-date {
        color: rgba(255,255,255,0.7);
        font-size: 0.83rem;
        margin: 0.2rem 0 0;
    }

    .privacy-card {
        background: white;
        border: 1px solid rgba(108,99,255,0.1);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        box-shadow: 0 8px 30px rgba(108,99,255,0.09);
    }

    .privacy-section {
        margin-bottom: 2rem;
    }

        .privacy-section:last-child {
            margin-bottom: 0;
        }

    .section-heading {
        font-family: 'Syne',sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #1A1A2E;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.8rem;
    }

        .section-heading .h-icon {
            width: 32px;
            height: 32px;
            background: rgba(108,99,255,0.1);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6C63FF;
            font-size: 0.95rem;
            flex-shrink: 0;
        }

    .section-text {
        color: #4A4A6A;
        font-size: 0.9rem;
        line-height: 1.75;
        margin: 0;
    }

    .divider-line {
        border: none;
        border-top: 1px solid rgba(108,99,255,0.08);
        margin: 1.5rem 0;
    }

    .contact-box {
        background: linear-gradient(135deg,rgba(108,99,255,0.06),rgba(56,189,248,0.06));
        border: 1px solid rgba(108,99,255,0.14);
        border-radius: 14px;
        padding: 1.2rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

        .contact-box i {
            font-size: 1.4rem;
            color: #6C63FF;
            flex-shrink: 0;
        }

        .contact-box p {
            margin: 0;
            font-size: 0.88rem;
            color: #4A4A6A;
            font-weight: 500;
        }

        .contact-box a {
            color: #6C63FF;
            font-weight: 700;
            text-decoration: none;
        }

    img {
        max-width: 100%;
        height: auto;
    }

    @@media (max-width: 768px) {
        .privacy-wrapper {
            margin: 1rem auto;
            padding: 0 0.75rem 1.5rem;
        }

        .privacy-hero {
            padding: 1.5rem 1rem;
        }

        .privacy-hero-inner {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.8rem;
        }

        .privacy-card {
            padding: 1.2rem;
        }

        .contact-box {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 576px) {
        .privacy-title {
            font-size: 1.35rem;
        }

        .section-heading {
            font-size: 0.95rem;
        }
    }
</style>

<div class="privacy-wrapper">
    <!-- Hero -->
    <div class="privacy-hero">
        <div class="privacy-hero-inner">
            <div class="privacy-hero-icon"><i class="bi bi-shield-check"></i></div>
            <div>
                <h1 class="privacy-title">Privacy Policy</h1>
                <p class="privacy-date">Last updated: January 2026</p>
            </div>
        </div>
    </div>

    <!-- Content Card -->
    <div class="privacy-card">
        <div class="privacy-section">
            <h2 class="section-heading">
                <div class="h-icon"><i class="bi bi-info-circle"></i></div>
                Overview
            </h2>
            <p class="section-text">
                This Privacy Policy describes how RegistrationFormProject collects, uses, and shares information
                about you when you use our services. We are committed to protecting your personal data and
                ensuring transparency in how we handle it.
            </p>
        </div>

        <hr class="divider-line">

        <div class="privacy-section">
            <h2 class="section-heading">
                <div class="h-icon"><i class="bi bi-database"></i></div>
                Information We Collect
            </h2>
            <p class="section-text">
                We collect information you provide directly to us, such as your full name, username, email
                address, mobile number, date of birth, and gender when you register or update your account.
                We may also collect technical data such as IP addresses and browser information to ensure
                security and proper system functioning.
            </p>
        </div>

        <hr class="divider-line">

        <div class="privacy-section">
            <h2 class="section-heading">
                <div class="h-icon"><i class="bi bi-gear"></i></div>
                How We Use Your Information
            </h2>
            <p class="section-text">
                Your information is used solely to operate, maintain, and improve our registration system.
                We use it to authenticate your identity, manage your account, communicate important updates,
                and provide a personalized experience. We do not sell or share your personal information
                with third parties for marketing purposes.
            </p>
        </div>

        <hr class="divider-line">

        <div class="privacy-section">
            <h2 class="section-heading">
                <div class="h-icon"><i class="bi bi-lock"></i></div>
                Data Security
            </h2>
            <p class="section-text">
                We implement industry-standard security measures including encrypted data storage and
                secure authentication protocols to safeguard your personal information. Despite our
                best efforts, no method of transmission over the internet is 100% secure, and we
                encourage users to protect their login credentials.
            </p>
        </div>

        <hr class="divider-line">

        <div class="privacy-section">
            <h2 class="section-heading">
                <div class="h-icon"><i class="bi bi-person-check"></i></div>
                Your Rights
            </h2>
            <p class="section-text">
                You have the right to access, correct, or delete your personal data at any time.
                Administrators can update user information through the User Management panel. If you
                wish to exercise any of your data rights or have concerns about your privacy, please
                contact our support team.
            </p>
        </div>

        <hr class="divider-line">

        <div class="contact-box">
            <i class="bi bi-envelope-at"></i>
            <p>
                Questions about this policy? Contact us at
                <a href="mailto:privacy@regsystem.com">privacy@regsystem.com</a>
                and we'll get back to you within 48 hours.
            </p>
        </div>
    </div>
</div>
