@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">


<head>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
          href="~/css/errorlog.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap"
          rel="stylesheet">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Registration</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/css/admin-theme.css" />
    <link rel="stylesheet" href="~/Registration.styles.css" asp-append-version="true" />

    <!-- Google Fonts -->

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            /* === 3D ORBS BACKGROUND === */
            .orb {
                position: fixed;
                border-radius: 50%;
                filter: blur(60px);
                pointer-events: none;
                z-index: 0;
                animation: orbFloat 8s ease-in-out infinite;
            }

            .orb-1 {
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(108,99,255,0.15), transparent 70%);
                top: -100px;
                left: -100px;
                animation-delay: 0s;
            }

            .orb-2 {
                width: 300px;
                height: 300px;
                background: radial-gradient(circle, rgba(56,189,248,0.12), transparent 70%);
                top: 40%;
                right: -80px;
                animation-delay: -3s;
            }

            .orb-3 {
                width: 250px;
                height: 250px;
                background: radial-gradient(circle, rgba(255,107,107,0.1), transparent 70%);
                bottom: 10%;
                left: 30%;
                animation-delay: -6s;
            }
            @@keyframes orbFloat {
                0%, 100% {
                    transform: translate(0,0) scale(1);
                }

                33% {
                    transform: translate(20px,-30px) scale(1.05);
                }

                66% {
                    transform: translate(-15px,20px) scale(0.97);
                }
            }

            /* === NAVBAR === */
            .top-navbar {
                background: rgba(255,255,255,0.88);
                backdrop-filter: blur(24px);
                -webkit-backdrop-filter: blur(24px);
                border-bottom: 1px solid rgba(108,99,255,0.12);
                box-shadow: 0 4px 30px rgba(108,99,255,0.08);
                position: sticky;
                top: 0;
                z-index: 999;
            }

            .navbar-brand-text {
                font-family: 'Syne', sans-serif;
                font-weight: 800;
                font-size: 1.25rem;
                background: linear-gradient(135deg, #6C63FF, #38BDF8);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                letter-spacing: -0.5px;
            }

            .top-nav-link {
                color: #4A4A6A !important;
                font-weight: 600;
                font-size: 0.88rem;
                padding: 0.4rem 1rem !important;
                border-radius: 50px;
                transition: all 0.25s ease;
            }

                .top-nav-link:hover {
                    color: #6C63FF !important;
                    background: rgba(108,99,255,0.08);
                }

                .top-nav-link.logout-link {
                    color: #FF6B6B !important;
                }

                    .top-nav-link.logout-link:hover {
                        background: rgba(255,107,107,0.08);
                    }

            .user-pill {
                background: linear-gradient(135deg, rgba(108,99,255,0.1), rgba(56,189,248,0.1));
                border: 1px solid rgba(108,99,255,0.2);
                border-radius: 50px;
                padding: 0.3rem 1rem;
                font-size: 0.83rem;
                font-weight: 600;
                color: #6C63FF;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }

            /* === SIDEBAR === */
            .admin-sidebar {
                background: linear-gradient(170deg, #6C63FF 0%, #8B5CF6 60%, #A78BFA 100%);
                min-height: calc(100vh - 60px);
                padding: 1.8rem 1rem;
                position: relative;
                overflow: hidden;
                box-shadow: 4px 0 40px rgba(108,99,255,0.2);
            }

                .admin-sidebar::before {
                    content: '';
                    position: absolute;
                    top: -80px;
                    right: -60px;
                    width: 220px;
                    height: 220px;
                    border-radius: 50%;
                    background: rgba(255,255,255,0.1);
                    pointer-events: none;
                }

                .admin-sidebar::after {
                    content: '';
                    position: absolute;
                    bottom: -100px;
                    left: -60px;
                    width: 260px;
                    height: 260px;
                    border-radius: 50%;
                    background: rgba(255,255,255,0.07);
                    pointer-events: none;
                }

            .sidebar-label {
                font-size: 0.68rem;
                font-weight: 700;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: rgba(255,255,255,0.55);
                padding: 0 0.8rem;
                margin-bottom: 0.8rem;
                margin-top: 1rem;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 0.65rem;
                color: rgba(255,255,255,0.85) !important;
                font-weight: 600;
                font-size: 0.88rem;
                padding: 0.7rem 1rem;
                border-radius: 12px;
                text-decoration: none;
                transition: all 0.25s ease;
                margin-bottom: 3px;
                position: relative;
                z-index: 1;
            }

                .sidebar-link:hover, .sidebar-link.active {
                    background: rgba(255,255,255,0.2);
                    color: #fff !important;
                    transform: translateX(5px);
                }

                .sidebar-link i {
                    font-size: 1rem;
                    width: 20px;
                    text-align: center;
                }

            .sidebar-avatar {
                background: rgba(255,255,255,0.2);
                border-radius: 16px;
                padding: 1rem;
                margin-bottom: 1.5rem;
                position: relative;
                z-index: 1;
                border: 1px solid rgba(255,255,255,0.25);
                backdrop-filter: blur(10px);
            }

                .sidebar-avatar .avatar-circle {
                    width: 48px;
                    height: 48px;
                    border-radius: 50%;
                    background: rgba(255,255,255,0.3);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 1.3rem;
                    font-weight: 700;
                    color: white;
                    border: 2px solid rgba(255,255,255,0.5);
                    margin-bottom: 0.5rem;
                }

                .sidebar-avatar .admin-name {
                    color: white;
                    font-weight: 700;
                    font-size: 0.9rem;
                }

                .sidebar-avatar .admin-role {
                    color: rgba(255,255,255,0.65);
                    font-size: 0.75rem;
                }

            /* === MAIN CONTENT === */
            .main-content {
                position: relative;
                z-index: 1;
                padding: 2rem;
            }

            /* === FOOTER === */
            .site-footer {
                background: rgba(255,255,255,0.9);
                backdrop-filter: blur(12px);
                border-top: 1px solid rgba(108,99,255,0.12);
                padding: 1rem 0;
                font-size: 0.83rem;
                color: #9898B5;
                font-weight: 500;
                text-align: center;
                position: relative;
                z-index: 1;
            }

                .site-footer a {
                    color: #6C63FF;
                    text-decoration: none;
                }

            /* === PAGE WRAPPER === */
            .page-wrapper {
                flex: 1;
                display: flex;
                flex-direction: column;
                position: relative;
            }
    </style>
</head>

<body>
    <!-- 3D Ambient Orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- TOP NAVBAR -->
    <header>
        <nav class="navbar top-navbar navbar-expand-sm px-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Home" asp-action="Index">
                    <div style="width:32px;height:32px;background:linear-gradient(135deg,#6C63FF,#38BDF8);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-layers text-white" style="font-size:0.9rem;"></i>
                    </div>
                    <span class="navbar-brand-text">Registration</span>
                </a>

                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">

                        @if (Context.Session.GetString("UserName") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link top-nav-link" asp-controller="Register" asp-action="Index">
                                    <i class="bi bi-person-plus me-1"></i>Register
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link top-nav-link" asp-controller="Login" asp-action="Index">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>

                        }
                        else
                        {
                            <li class="nav-item">
                                <div class="user-pill">
                                    <i class="bi bi-person-circle"></i>
                                    @Context.Session.GetString("UserName")
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link top-nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house me-1"></i>Home
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link top-nav-link"
                                   asp-controller="Document"
                                   asp-action="Upload">
                                    <i class="bi bi-file-earmark-arrow-up me-1"></i>
                                    Documents
                                </a>
                            </li>

                            @if (Context.Session.GetInt32("RoleId") == 1)
                            {
                                <li class="nav-item">
                                    <a class="nav-link top-nav-link" asp-controller="Admin" asp-action="UserList">
                                        <i class="bi bi-people me-1"></i>Users
                                    </a>
                                </li>
                            }
                            
                                <li class="nav-item">

                                    <form asp-controller="Login"
                                          asp-action="Logout"
                                          method="post"
                                          class="d-inline">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="nav-link top-nav-link logout-link border-0 bg-transparent">

                                            <i class="bi bi-box-arrow-right me-1"></i>

                                            Logout

                                        </button>

                                    </form>

                                </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- PAGE LAYOUT -->
    <div class="page-wrapper">
        <div class="container-fluid p-0" style="position:relative;z-index:1;">
            <div class="row g-0">

                @if (Context.Session.GetInt32("RoleId") == 1)
                {
                    <!-- ADMIN SIDEBAR -->
                    <div class="col-md-2">
                        <div class="admin-sidebar">
                            <div class="sidebar-avatar">
                                <div class="avatar-circle">A</div>
                                <div class="admin-name">Admin Panel</div>
                                <div class="admin-role">Super Administrator</div>
                            </div>

                            <div class="sidebar-label">Navigation</div>

                            <a class="sidebar-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Dashboard
                            </a>

                            <a class="sidebar-link" asp-controller="Admin" asp-action="UserList">
                                <i class="bi bi-people"></i> User Master
                            </a>

                            <a class="sidebar-link"
                               asp-controller="Role"
                               asp-action="Index">
                                <i class="bi bi-shield-check"></i> Role Master
                            </a>

                            <a class="sidebar-link"
                               asp-controller="DocumentVerification"
                               asp-action="Index">
                                <i class="bi bi-file-earmark-check"></i> Document Verification
                            </a>

                            <a class="sidebar-link
                                @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ErrorLog" ? "active" : "")"
                               asp-controller="ErrorLog"
                               asp-action="Index">

                                <i class="bi bi-bug-fill"></i>

                                Error Logs

                                @if (ViewBag.NewErrors > 0)
                                {
                                    <span class="badge rounded-pill bg-danger ms-auto">
                                        @ViewBag.NewErrors
                                    </span>
                                }

                            </a>

                            <div class="sidebar-label" style="margin-top:1.5rem;">Account</div>
                            <form asp-controller="Login"
                                  asp-action="Logout"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="sidebar-link border-0 bg-transparent w-100 text-start">

                                    <i class="bi bi-box-arrow-right"></i>

                                    Logout

                                </button>

                            </form>
                        </div>
                    </div>

                    <!-- MAIN CONTENT -->
                    <div class="col-md-10">
                        <div class="main-content">
                            @RenderBody()
                        </div>
                    </div>
                }
                else
                {
                    <div class="col-12">
                        <main class="main-content">
                            @RenderBody()
                        </main>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="container">
            &copy; 2026 <strong>Registration</strong> — All rights reserved &nbsp;|&nbsp;
            <a href="#">Privacy</a> &nbsp;|&nbsp; <a href="#">Terms</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>

</html>
