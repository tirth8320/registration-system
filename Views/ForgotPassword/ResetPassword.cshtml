@{
    ViewData["Title"] = "Reset Password";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 mx-auto"
         style="max-width:500px;border-radius:20px;">

        <h2 class="text-center mb-4">
            Reset Password
        </h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <form asp-action="ResetPassword"
              method="post">

            <div class="mb-3">
                <label>New Password</label>

                <input type="password"
                       name="newPassword"
                       class="form-control"
                       required />
            </div>

            <div class="mb-3">
                <label>Confirm Password</label>

                <input type="password"
                       name="confirmPassword"
                       class="form-control"
                       required />
            </div>

            <button type="submit"
                    class="btn btn-warning w-100">
                Reset Password
            </button>

        </form>

    </div>
</div>