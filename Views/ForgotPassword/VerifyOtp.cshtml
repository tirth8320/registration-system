@{
    ViewData["Title"] = "Verify OTP";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 mx-auto"
         style="max-width:500px;border-radius:20px;">

        <h2 class="text-center mb-4">
            Verify OTP
        </h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <form asp-action="VerifyOtp" method="post">

            <div class="mb-3">
                <label class="form-label">
                    Enter OTP
                </label>

                <input type="text"
                       name="otp"
                       class="form-control"
                       required />
            </div>

            <button type="submit"
                    class="btn btn-success w-100">
                Verify OTP
            </button>

        </form>

    </div>
</div>