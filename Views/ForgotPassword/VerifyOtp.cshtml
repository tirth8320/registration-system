@{
    ViewData["Title"] = "Verify OTP";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 mx-auto"
         style="max-width:500px;border-radius:20px;">

        <h2 class="text-center mb-4">
            Verify OTP
        </h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <form asp-action="VerifyOtp" method="post">

            <div class="mb-3">
                <label class="form-label">
                    Enter OTP
                </label>

                <input type="text"
                       name="otp"
                       class="form-control"
                       required />
            </div>

            <button type="submit"
                    class="btn btn-success w-100">
                Verify OTP
            </button>

        </form>

    </div>
</div>

<style>
    @@media (max-width: 768px) {
        .container {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        .card {
            width: 100%;
            max-width: 100% !important;
        }

        .form-control {
            width: 100%;
            font-size: 16px;
        }

        .btn {
            width: 100%;
            min-height: 48px;
        }
    }

    @@media (max-width: 576px) {
        .card {
            padding: 1rem !important;
        }

        h2 {
            font-size: 1.4rem;
        }
    }
</style>