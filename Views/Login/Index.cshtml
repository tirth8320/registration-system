@{
    ViewData["Title"] = "Login";
}

<style>
    .login-bg {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
    }

    /* 3D floating shapes */
    .shape {
        position: absolute;
        border-radius: 50%;
        animation: shapeFloat 6s ease-in-out infinite;
        pointer-events: none;
    }

    .shape-1 {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, rgba(108,99,255,0.25), rgba(56,189,248,0.25));
        top: 12%;
        left: 8%;
        animation-delay: 0s;
    }

    .shape-2 {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, rgba(255,107,107,0.2), rgba(255,142,83,0.2));
        top: 20%;
        right: 10%;
        border-radius: 30% 70% 60% 40%;
        animation-delay: -2s;
    }

    .shape-3 {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, rgba(52,211,153,0.2), rgba(56,189,248,0.2));
        bottom: 20%;
        left: 12%;
        border-radius: 60% 40% 30% 70%;
        animation-delay: -4s;
    }

    .shape-4 {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, rgba(139,92,246,0.25), rgba(108,99,255,0.25));
        bottom: 15%;
        right: 8%;
        animation-delay: -1s;
    }
    @@keyframes shapeFloat {
        0%, 100% {
            transform: translateY(0) rotate(0deg);
        }

        50% {
            transform: translateY(-18px) rotate(15deg);
        }
    }

    .login-card {
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid rgba(108,99,255,0.18);
        border-radius: 28px;
        box-shadow: 0 25px 70px rgba(108,99,255,0.18), 0 0 0 1px rgba(255,255,255,0.8) inset;
        width: 100%;
        max-width: 506px;
        padding: 2.8rem 2.5rem;
        position: relative;
        z-index: 2;
        animation: cardEntrance 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-style: preserve-3d;
    }
    @@keyframes cardEntrance {
        from {
            opacity: 0;
            transform: translateY(40px) scale(0.92);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .login-icon {
        width: 68px;
        height: 68px;
        background: linear-gradient(135deg, #6C63FF, #38BDF8);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: white;
        margin: 0 auto 1.5rem;
        box-shadow: 0 10px 30px rgba(108,99,255,0.35);
        animation: iconPulse 3s ease-in-out infinite;
    }
    @@keyframes iconPulse {
        0%, 100% {
            box-shadow: 0 10px 30px rgba(108,99,255,0.35);
        }

        50% {
            box-shadow: 0 10px 45px rgba(108,99,255,0.55);
        }
    }

    .login-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.9rem;
        font-weight: 800;
        color: #1A1A2E;
        text-align: center;
        margin-bottom: 0.3rem;
        letter-spacing: -0.5px;
    }

    .login-sub {
        text-align: center;
        color: #9898B5;
        font-size: 0.88rem;
        margin-bottom: 2rem;
        font-weight: 500;
    }

    .input-group-modern {
        position: relative;
        margin-bottom: 1.2rem;
    }

        .input-group-modern .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9898B5;
            font-size: 1rem;
            z-index: 2;
            transition: color 0.2s;
        }

        .input-group-modern .form-control {
            padding-left: 2.8rem;
            border: 1.5px solid rgba(108,99,255,0.18);
            border-radius: 12px;
            height: 50px;
            font-size: 0.92rem;
            background: rgba(246,247,251,0.8);
            transition: all 0.25s ease;
        }

            .input-group-modern .form-control:focus {
                border-color: #6C63FF;
                background: white;
                box-shadow: 0 0 0 4px rgba(108,99,255,0.1) !important;
            }

                .input-group-modern .form-control:focus + .input-icon,
                .input-group-modern:focus-within .input-icon {
                    color: #6C63FF;
                }

    .float-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #4A4A6A;
        margin-bottom: 0.35rem;
        display: block;
    }

    .btn-login {
        width: 100%;
        height: 50px;
        background: linear-gradient(135deg, #6C63FF, #8B5CF6);
        border: none;
        border-radius: 12px;
        color: white;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 6px 20px rgba(108,99,255,0.35);
        position: relative;
        overflow: hidden;
        margin-top: 0.5rem;
    }

        .btn-login::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s ease;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(108,99,255,0.45);
        }

            .btn-login:hover::before {
                left: 100%;
            }

        .btn-login:active {
            transform: translateY(0);
        }

    .divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: #C4C4D8;
        font-size: 0.8rem;
        font-weight: 500;
        margin: 1.5rem 0 1.2rem;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(108,99,255,0.12);
        }

    .register-link {
        text-align: center;
        font-size: 0.87rem;
        color: #9898B5;
        font-weight: 500;
    }

        .register-link a {
            color: #6C63FF;
            font-weight: 700;
            text-decoration: none;
        }

            .register-link a:hover {
                text-decoration: underline;
            }

    .alert-danger {
        background: #fff1f2;
        border: 1px solid #fecdd3;
        color: #dc2626;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 15px;
        font-weight: 600;
    }

    #captchaBox {
        width: 220px;
        height: 70px;
        border-radius: 16px;
        border: 1px solid #d9dbff;
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: url('/images/captcha-noise.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        color: rgba(108,99,255,0.25);
        filter: contrast(1.0);
        font-size: 32px;
        font-weight: 900;
        letter-spacing: 4px;
        text-shadow: 2px 2px 3px rgba(255,255,255,0.7), -2px -2px 3px rgba(0,0,0,0.2);
        user-select: none;
        overflow: hidden;
        position: relative;
        transition: all .2s ease;
    }

        #captchaBox::before {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(1px);
            pointer-events: none;
        }
    /* ===========================
          SHOW PASSWORD ICON
    =========================== */

    .toggle-password{

        position:absolute;

        right:16px;

        top:53px;

        transform:translateY(-50%);

        cursor:pointer;

        color:#8A8AA3;

        font-size:18px;

        transition:.25s;

        z-index:5;

    }

    .toggle-password:hover{

        color:#6C63FF;

}
    
</style>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<div class="login-bg">
    <!-- Floating shapes -->
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>

    <div class="login-card">
        <div class="login-icon">
            <i class="bi bi-shield-lock"></i>
        </div>

        <h1 class="login-title">Welcome Back</h1>
        <p class="login-sub">Sign in to your account to continue</p>

        <form asp-controller="Login"
              asp-action="Login"
              method="post">
            <div class="input-group-modern">
                <label class="float-label">User Name</label>
                <input type="text" name="username" class="form-control" placeholder="Enter your username" />
                <i class="bi bi-person input-icon" style="top: calc(50% + 13px);"></i>
            </div>

            <div class="input-group-modern">
                <label class="float-label">Password</label>
                <input type="password"
                       id="password"
                       name="password"
                       class="form-control pe-5"
                       placeholder="Enter your password" />
                <i class="bi bi-lock input-icon"
                   style="top: calc(50% + 13px);"></i>

                <i class="bi bi-eye-slash toggle-password"
                   id="togglePassword"
                   onclick="togglePassword()"></i>
            </div>
            <div class="text-end mb-3">
                <a asp-controller="ForgotPassword"
                   asp-action="Index"
                   style="text-decoration:none;">
                    Forgot Password?
                </a>
            </div>

            <div class="input-group-modern">

                <label class="float-label">Captcha Verification</label>

                <div style="display:flex;gap:10px;align-items:center;margin-bottom:12px;">

                    <div id="captchaBox"
                         style="
                        width:220px;
                        height:70px;
                        background:#F5F6FF;
                        border:1px solid #d9dbff;
                        border-radius:16px;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        color:#6C63FF;
                        font-size:34px;
                        font-weight:800;
                        letter-spacing:4px;
                        user-select:none;">
                    </div>

                    <button type="button"
                            onclick="loadCaptcha()"
                            style="
                        width:60px;
                        height:70px;
                        border:none;
                        border-radius:16px;
                        background:#EEF1FF;
                        color:#6C63FF;
                        font-size:24px;">
                        ↻
                    </button>

                </div>

                <input type="text"
                       name="CaptchaInput"
                       class="form-control"
                       placeholder="Enter Captcha"
                       required />

            </div>

            <button type="submit" class="btn-login">
                <i class="bi bi-box-arrow-in-right me-2"></i>
                Sign In
            </button>
        </form>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-danger mt-3">
                <i class="bi bi-exclamation-circle"></i>
                @ViewBag.Message
            </div>
        }

        <div class="divider">or</div>

        <div class="register-link">
            Don't have an account? &nbsp;<a asp-controller="Register" asp-action="Index">Create one</a>
        </div>
    </div>
    <script>

            function loadCaptcha() {

                fetch('/Captcha/GenerateCaptcha')
                    .then(response => response.text())
                    .then(data => {

                        document.getElementById('captchaBox').innerText = data;

                    });

            }

            window.onload = function () {
                loadCaptcha();
            };
                        function togglePassword()
            {
                var password = document.getElementById("password");

                var icon = document.getElementById("togglePassword");

                if(password.type==="password")
                {
                    password.type="text";

                    icon.classList.remove("bi-eye-slash");

                    icon.classList.add("bi-eye");
                }
                else
                {
                    password.type="password";

                    icon.classList.remove("bi-eye");

                    icon.classList.add("bi-eye-slash");
                }
            }

    </script>
</div>
